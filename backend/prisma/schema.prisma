datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
}

enum MeetingStatus {
  SCHEDULED
  ONGOING
  ENDED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model School {
  id            Int                   @id @default(autoincrement())
  name          String
  domain        String?               @unique
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  users         User[]
  subscriptions Subscription[]
  meetings      Meeting[]
  assignments   Assignment[]
  attendances   Attendance[]
  teacherAttendances TeacherAttendance[]
}

model Subscription {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  planName  String
  status    String
  startDate DateTime @default(now())
  endDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model User {
  id          Int      @id @default(autoincrement())
  schoolId    Int?
  name        String
  email       String   @unique
  password    String
  role        Role     @default(STUDENT)
  // Student-specific fields
  rollNo      String?  // e.g. "23", null for non-students
  standard    String?  // e.g. "10A", "9B" — class/section, null for non-students
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school             School?      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  hostedMeetings     Meeting[]    @relation("MeetingHost")
  createdAssignments Assignment[] @relation("AssignmentCreator")
  submissions        Submission[]
  // Attendance records for this student
  attendanceRecords  Attendance[] @relation("StudentAttendance")
  // Attendance records marked by this teacher
  markedAttendances  Attendance[] @relation("TeacherAttendance")
  // This teacher's own daily check-ins
  selfAttendances    TeacherAttendance[]
}

model Meeting {
  id          Int           @id @default(autoincrement())
  schoolId    Int
  hostId      Int
  title       String
  meetingLink String
  status      MeetingStatus @default(SCHEDULED)
  // Which class this meeting is for — only students of this standard can see it
  standard    String?       // e.g. "10A". If null, visible to whole school
  startTime   DateTime?
  endTime     DateTime?
  createdAt   DateTime      @default(now())
  school      School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  host        User          @relation("MeetingHost", fields: [hostId], references: [id], onDelete: Cascade)
}

model Assignment {
  id          Int          @id @default(autoincrement())
  schoolId    Int
  teacherId   Int
  title       String
  description String
  fileUrl     String?
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher     User         @relation("AssignmentCreator", fields: [teacherId], references: [id], onDelete: Cascade)
  submissions Submission[]
}

model Submission {
  id           Int        @id @default(autoincrement())
  assignmentId Int
  studentId    Int
  fileUrl      String
  submittedAt  DateTime   @default(now())
  grade        String?
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  @@unique([assignmentId, studentId])
}

// Attendance: one record per student per date (marked by teacher)
model Attendance {
  id        Int              @id @default(autoincrement())
  schoolId  Int
  teacherId Int              // who marked it
  studentId Int              // whose attendance
  standard  String           // which class (e.g. "10A")
  date      DateTime         // the date (store at midnight UTC)
  status    AttendanceStatus @default(PRESENT)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  school  School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher User   @relation("TeacherAttendance", fields: [teacherId], references: [id], onDelete: Cascade)
  student User   @relation("StudentAttendance", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date]) // one record per student per day
}

// Teacher self-attendance: one check-in per teacher per day, resets daily
// (i.e. "today's" record is just whatever exists for today's date — there's
// nothing to explicitly reset, a new day simply has no row yet).
model TeacherAttendance {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  teacherId Int
  date      DateTime // the date (stored at midnight UTC), one row per day
  checkedInAt DateTime @default(now()) // exact time the teacher marked present

  school  School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher User   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, date])
}

model RegistrationRequest {
  id              Int           @id @default(autoincrement())
  schoolName      String
  domain          String?
  adminName       String
  adminEmail      String
  password        String
  status          RequestStatus @default(PENDING)
  rejectionReason String?
  reviewedByName  String?
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
}
