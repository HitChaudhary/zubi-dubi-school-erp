# --- Database (used by Prisma) ---
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DATABASE_URL=

# --- Auth ---
# Used to sign JWTs. Falls back to a hardcoded dev value if unset — set a real
# secret before deploying anywhere real users can reach.
JWT_SECRET=

# --- Server ---
PORT=5000

# --- SMTP (school-registration email notifications) ---
# All four of these must be set or the mailer logs to the console instead of sending.
# Gmail: smtp.gmail.com / 587 / SMTP_SECURE=false — requires a Google "App Password"
#        (regular account passwords are rejected once 2FA is on).
# Outlook: smtp.office365.com / 587 / SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Optional — defaults to SMTP_USER if unset
SMTP_FROM=
